# ─── FIREBASE ────────────────────────────────────────────────────────────────
# Encontre em: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=painel-administrativo-81681

# Service Account em base64.
# Gere em: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Converta: base64 -i serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=base64_do_seu_service_account_json

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
FRONTEND_URL=https://painel.meusapps.com
PORT=3000

# ─── DESENVOLVIMENTO LOCAL ────────────────────────────────────────────────────
# FRONTEND_URL=http://localhost:5173
